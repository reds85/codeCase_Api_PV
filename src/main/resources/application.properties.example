spring.application.name=codecaseapi

server.port=9002

# Niveau de logging
logging.level.root=error
# pour le package
logging.level.fr.afpa.codecaseapi=info
# pour la BDD
logging.level.org.springframework.data=INFO
logging.level.org.springframework.jdbc.core.JdbcTemplate=DEBUG
# niveau de logging pour TOMCAT
logging.level.org.springframework.boot.web.embedded.tomcat=INFOS

spring.datasource.url=jdbc:mysql://localhost:3306/codecase
spring.datasource.username=
spring.datasource.password= 
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

#A LAISSER SOUS NONE
spring.jpa.hibernate.ddl-auto=none

spring.jpa.hibernate.naming.physical-strategy=org.hibernate.boot.model.naming.PhysicalNamingStrategyStandardImpl
